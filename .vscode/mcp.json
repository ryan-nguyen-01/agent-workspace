{
  "servers": {
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/v1",
      "headers": {
        "Authorization": "Bearer ${FIGMA_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "figma-local": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@figma/mcp-server", "--stdio"]
    }
  }
}
