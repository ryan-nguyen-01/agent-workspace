{
  "framework": {
    "version": "1.7.0",
    "name": "agent-workspace"
  },
  "workflow": {
    "code_done_threshold": 0.8,
    "qc_handoff_required": true,
    "blocker_stops_qc": true,
    "coder_creation_requires_approval": true,
    "memory_updates_enabled": true
  },
  "agents": {
    "max_generated_coders": 10,
    "default_test_policy": "follow_project_conventions"
  },
  "memory": {
    "memory_index_path": ".runtime/context/index.yaml",
    "project_brain_path": ".runtime/context/project-brain.yaml",
    "service_memory_dir": ".runtime/context/services",
    "git_ignore_memory": true
  },
  "services": {
    "service_catalog_path": ".runtime/context/service-catalog.yaml",
    "agent_registry_path": ".runtime/context/agent-registry.yaml",
    "test_policy_path": ".runtime/context/test-policy.yaml",
    "skill_registry_path": ".runtime/context/skill-registry.yaml"
  },
  "state": {
    "workflow_state_path": ".runtime/context/workflow-state.yaml"
  },
  "conventions": {
    "task_id_format": "TASK-{number}",
    "bug_id_format": "BUG-{number}",
    "commit_format": "conventional"
  }
}
