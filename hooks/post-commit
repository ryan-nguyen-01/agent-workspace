#!/bin/sh
# agent-platform post-commit hook
# Notify agent-context-keeper to sync .agent/ context after each commit

AGENT_DIR=".agent"
DIRTY_FLAGS="$AGENT_DIR/dirty-flags.md"
CHANGELOG="$AGENT_DIR/changelog.md"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
CHANGED_FILES=$(git diff HEAD~1 --name-only 2>/dev/null | head -50)

# Only run if .agent/ exists (project has been onboarded)
if [ ! -d "$AGENT_DIR" ]; then
  exit 0
fi

# Mark dirty sections based on changed files
cat > "$DIRTY_FLAGS" << EOF
---
dirty_sections: []
sync_in_progress: false
pending_trigger:
  source: git_commit
  changed_files:
$(echo "$CHANGED_FILES" | sed 's/^/    - /')
  marked_at: $TIMESTAMP
last_checked: $TIMESTAMP
---
EOF

# Append to changelog
echo "[$TIMESTAMP] trigger: git_commit | files_changed: $(echo "$CHANGED_FILES" | wc -l | tr -d ' ')" >> "$CHANGELOG"

echo "[agent-platform] Context sync triggered (post-commit)"
