{
  "_comment": "Verify schema against current Kiro agent-hook docs before relying on in CI. Kiro-only; mirrors scripts/hooks + .cursor/hooks intent.",
  "enabled": true,
  "name": "Maestro drift check",
  "description": "When framework engine files change, run the architecture health check and report drift.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      ".maestro/engine/**",
      ".claude/agents/**",
      ".claude/commands/**",
      "scripts/**"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run `python3 scripts/architecture-health-check.py --strict` and report any drift (counts, required files, entrypoint references). If counts changed intentionally, update EXPECTED_COUNTS and the doc mentions. Do not commit secrets."
  }
}
