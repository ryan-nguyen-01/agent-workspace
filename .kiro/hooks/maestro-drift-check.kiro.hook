{
  "enabled": true,
  "name": "Maestro drift check",
  "description": "When framework engine/agent/command/script files are saved, run the architecture health check and report drift.",
  "version": "1",
  "when": {
    "type": "fileSave",
    "patterns": [
      ".maestro/engine/**",
      ".claude/agents/**",
      ".claude/commands/**",
      "scripts/**"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run `python3 scripts/architecture-health-check.py --strict` and report any drift (counts, required files, entrypoint references). If counts changed intentionally, update EXPECTED_COUNTS and the doc mentions. Do not commit secrets."
  }
}
