{
  "enabled": true,
  "name": "Maestro secret scan",
  "description": "On file save, ensure no secrets, keys, tokens, or .env values were introduced (R-013).",
  "version": "1",
  "when": {
    "type": "fileSave",
    "patterns": ["**/*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Check the saved file for secrets, private keys, API tokens, passwords, or real .env values (R-013). If any are present, stop and tell the user; never commit them. Keep runtime/session files out of version control."
  }
}
