{
  "_comment": "Verify schema against current Kiro agent-hook docs. Kiro-only; complements scripts/hooks/secret-guard.py (R-013).",
  "enabled": true,
  "name": "Maestro secret scan",
  "description": "On file save, ensure no secrets, keys, tokens, or .env values were introduced.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": ["**/*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Check the edited file for secrets, private keys, API tokens, passwords, or real .env values (R-013). If any are present, stop and tell the user; never commit them. Keep runtime/session files out of version control."
  }
}
