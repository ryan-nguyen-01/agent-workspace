{
  "framework": {
    "version": "1.8.0",
    "name": "maestro"
  },
  "workflow": {
    "code_done_threshold": 0.8,
    "qc_handoff_required": true,
    "blocker_stops_qc": true,
    "coder_creation_requires_approval": true,
    "memory_updates_enabled": true
  },
  "agents": {
    "max_generated_coders": 10,
    "default_test_policy": "follow_project_conventions"
  },
  "memory": {
    "memory_index_path": ".maestro/knowledge/index.yaml",
    "project_brain_path": ".maestro/knowledge/project.yaml",
    "service_memory_dir": ".maestro/knowledge/components",
    "git_ignore_memory": true
  },
  "services": {
    "service_catalog_path": ".maestro/registry/components.yaml",
    "agent_registry_path": ".maestro/registry/agents.yaml",
    "test_policy_path": ".maestro/knowledge/test-policy.yaml",
    "skill_registry_path": ".maestro/registry/skills.yaml"
  },
  "state": {
    "workflow_state_path": ".maestro/runtime/workflow-state.yaml"
  },
  "conventions": {
    "task_id_format": "TASK-{number}",
    "bug_id_format": "BUG-{number}",
    "commit_format": "conventional"
  },
  "_comment_hooks": "SCOPE: Claude Code only. Runtime controls via env: MAESTRO_HOOK_PROFILE=minimal|standard|strict (default standard), MAESTRO_DISABLED_HOOKS=comma,ids. scope-guard + secret-guard gate Write/Edit; destructive-guard gates Bash. See .maestro/engine/rules/17-hook-enforcement-rules.md and SETUP.md.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/scope-guard.py\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/secret-guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/hooks/destructive-guard.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
