{
  "PreToolUse": [
    {
      "matcher": "Write|Edit|MultiEdit|NotebookEdit",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/scope-guard.py\"",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/secret-guard.py\"",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/destructive-guard.py\"",
          "timeout": 5
        }
      ]
    }
  ]
}
