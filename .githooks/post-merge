#!/bin/sh
# agent-platform post-merge hook
# Notify agent-context-keeper after git pull/merge — potentially many changes

AGENT_DIR=".agent"
DIRTY_FLAGS="$AGENT_DIR/dirty-flags.md"
CHANGELOG="$AGENT_DIR/changelog.md"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
CHANGED_FILES=$(git diff HEAD@{1} --name-only 2>/dev/null | head -50)
FILE_COUNT=$(echo "$CHANGED_FILES" | grep -c . 2>/dev/null || echo "0")

if [ ! -d "$AGENT_DIR" ]; then
  exit 0
fi

cat > "$DIRTY_FLAGS" << EOF
---
dirty_sections: []
sync_in_progress: false
pending_trigger:
  source: git_pull
  changed_files:
$(echo "$CHANGED_FILES" | sed 's/^/    - /')
  marked_at: $TIMESTAMP
last_checked: $TIMESTAMP
---
EOF

echo "[$TIMESTAMP] trigger: git_pull | files_changed: $FILE_COUNT" >> "$CHANGELOG"

echo "[agent-platform] Context sync triggered (post-merge) — $FILE_COUNT files changed"

